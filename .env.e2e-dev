# Override .env.local when running `npm run dev` against the docker e2e stack.
# Source via `set -a; source .env.e2e-dev; set +a; npm run dev` or use dotenv-cli.

DATABASE_URL=postgres://e2e:e2e@localhost:54329/brand_creator_e2e
DIRECT_URL=postgres://e2e:e2e@localhost:54329/brand_creator_e2e

NEXTAUTH_URL=http://localhost:12000
NEXTAUTH_SECRET=e2e-nextauth-secret-not-prod

# Supabase Storage via the path-rewriting proxy on host port 54331.
SUPABASE_URL=http://localhost:54331
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJyb2xlIjoic2VydmljZV9yb2xlIiwiaXNzIjoic3VwYWJhc2UiLCJpYXQiOjE3MDAwMDAwMDAsImV4cCI6NDAwMDAwMDAwMH0.ioNpxDRMKY2wlaj0A6Jf6bHNoNBFz7YWsVhEj0cOUfo

# Backend FastAPI exposed by docker on 8001.
NEXT_PUBLIC_API_URL=http://localhost:8001
CAMPAIGNS_API_URL=http://localhost:8001

# Enables /api/test/login endpoint for fast role switching.
E2E_EXPLORE=1
