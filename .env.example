NEXTAUTH_SECRET=
NEXTAUTH_URL=

DATABASE_URL=
DIRECT_URL=

# Drift hook: must point at a NON-PRODUCTION Postgres (local or branch).
# Never set this to your production database — Prisma creates/drops schemas during migrate diff.
SHADOW_DATABASE_URL=

# AI video task workflow (Storyclaw)
# Used by /api/ai-videos/tasks and /storyclaw-admin pages.
# Run `npm run studio:create-buckets` once to provision the `ai-video-tasks` bucket.
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

SMTP_HOST=
SMTP_PORT=
SMTP_SECURE=
SMTP_USER=
SMTP_PASSWORD=

TIKTOK_ACCESS_TOKEN=
TIKTOK_TCM_ACCOUNT_ID=
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=

NEXT_PUBLIC_APP_URL=
CAMPAIGNS_API_URL=
