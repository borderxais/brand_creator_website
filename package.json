{
  "name": "brand-creator-platform",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20.12.0"
  },
  "scripts": {
    "dev": "next dev -p 12000",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "format": "prettier --write .",
    "typecheck": "tsc --noEmit",
    "prepare": "husky && node scripts/harness/banner.js",
    "harness:install": "npm install && npm run prepare",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:seed": "node prisma/seed.js",
    "db:seed": "node prisma/seed.js",
    "db:seed:dev": "node --env-file=.env prisma/seed.dev.js",
    "studio:create-buckets": "node --env-file=.env scripts/studio-create-buckets.js",
    "lint:strict": "eslint . --max-warnings=0",
    "test": "vitest",
    "test:run": "vitest run",
    "e2e": "playwright test",
    "e2e:preview": "PLAYWRIGHT_BASE_URL=$DEPLOY_PRIME_URL playwright test e2e/smoke",
    "e2e:up": "tsx scripts/e2e/up.ts",
    "e2e:down": "tsx scripts/e2e/down.ts",
    "e2e:reset": "tsx scripts/e2e/reset-db.ts",
    "e2e:agent": "tsx scripts/e2e/agent.ts",
    "e2e:explore": "tsx scripts/e2e/explore.ts",
    "e2e:debug": "tsx scripts/e2e/debug.ts",
    "e2e:rebuild": "tsx scripts/e2e/rebuild.ts",
    "e2e:ci": "E2E_AGENT=1 playwright test",
    "harness:prepush": "npm run typecheck && npm run lint && node scripts/harness/prisma-drift.js && npm run test:run && cd backend && .venv/bin/ruff check . && .venv/bin/ruff format --check . && .venv/bin/mypy app",
    "harness:full": "npm run harness:prepush && npm run e2e"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,mjs}": [
      "prettier --write",
      "eslint --fix --max-warnings=0"
    ],
    "*.{ts,tsx}": [
      "tsc-files --noEmit"
    ],
    "prisma/schema.prisma": [
      "prisma format",
      "node scripts/harness/prisma-drift.js"
    ],
    "backend/**/*.py": [
      "backend/.venv/bin/ruff format",
      "backend/.venv/bin/ruff check --fix --exit-non-zero-on-fix"
    ],
    "*.{json,md,yml,yaml,css}": [
      "prettier --write"
    ]
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.7.4",
    "@next-auth/prisma-adapter": "^1.0.7",
    "@paralleldrive/cuid2": "^3.3.0",
    "@prisma/client": "^6.4.1",
    "@radix-ui/react-dialog": "^1.1.6",
    "@radix-ui/react-popover": "^1.1.6",
    "@radix-ui/react-slot": "^1.1.2",
    "@radix-ui/react-tabs": "^1.1.2",
    "@supabase/supabase-js": "^2.48.1",
    "axios": "^1.8.4",
    "bcrypt": "^5.1.1",
    "bcryptjs": "^2.4.3",
    "chart.js": "^4.4.8",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^3.3.1",
    "lucide-react": "^0.474.0",
    "next": "^15.5.9",
    "next-auth": "^4.24.11",
    "nodemailer": "^6.10.1",
    "prisma": "^6.4.1",
    "react": "^19.1.0",
    "react-chartjs-2": "^5.3.0",
    "react-day-picker": "^9.8.0",
    "react-dom": "^19.1.0",
    "react-icons": "^5.4.0",
    "recharts": "^2.15.1",
    "stripe": "^22.1.0",
    "tailwind-merge": "^3.0.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@faker-js/faker": "^9.5.1",
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/bcrypt": "^5.0.2",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.17.16",
    "@types/node-fetch": "^2.6.13",
    "@types/nodemailer": "^6.4.17",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.20",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9.24.0",
    "eslint-config-next": "^15.5.9",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^16.4.0",
    "postcss": "^8.5.1",
    "prettier": "^3.8.3",
    "tailwindcss": "^3.4.17",
    "ts-node": "^10.9.2",
    "tsc-files": "^1.1.4",
    "tsx": "^4.21.0",
    "typescript": "^5.8.2",
    "vitest": "^4.1.5"
  }
}
